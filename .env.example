# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=erp_unified_backend
DB_USER=postgres
DB_PASSWORD=hari

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-minimum-32-chars
JWT_REFRESH_SECRET=another-long-random-secret-for-refresh-tokens
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Accounting ───────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=NPR
DEFAULT_VAT_PERCENT=13
